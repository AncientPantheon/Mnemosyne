# ── AncientHub OIDC (Phase 2) ─────────────────────────────────────────────
# One-time prerequisite: register Mnemosyne as a CONFIDENTIAL OIDC client with the
# hub (ask the hub agent). You receive a stable client_id and a client_secret
# (shown once). Register BOTH redirect_uris BYTE-FOR-BYTE (exact match, no trailing
# slash): http://localhost:3005/admin/callback (local) and
# https://codex.ancientholdings.eu/admin/callback (prod). Until real creds land, the
# REPLACE_ME_* placeholders keep the login surface inert (boots dark, no crash).
# Flow: auth-code + PKCE(S256), scope "openid profile email roles", id_token RS256.
OIDC_ISSUER=https://ancientholdings.eu
OIDC_CLIENT_ID=REPLACE_ME_client_id
OIDC_CLIENT_SECRET=REPLACE_ME_client_secret
OIDC_REDIRECT_URI=http://localhost:3005/admin/callback
# Server-side session signing key (generated locally; ≥32 chars). Do not commit.
SESSION_SECRET=REPLACE_ME_run_openssl_rand_hex_32

# ── Operator Codex sealing (Phase 4) ──────────────────────────────────────
# 32-byte at-rest master key (base64) that seals the server-side operator codex
# stored under data/mnemosyne-codex/. Generate locally (like SESSION_SECRET) with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MNEMOSYNE_MASTER_KEY=REPLACE_ME_base64_of_32_random_bytes

# ── Khronoton engine (autonomous scheduler) ───────────────────────────────
# All optional — omit for defaults. The engine (tick loop + sqlite store) starts
# with the server (instrumentation.ts) and signs with the sealed operator codex.
# KHRONOTON_DISABLED=1            # kill switch: the tick loop never starts
# KHRONOTON_TICK_MS=30000         # tick cadence (ms)
# MNEMOSYNE_KHRONOTON_DIR=        # store dir; default <cwd>/data/khronoton
# KHRONOTON_NODE_BASE_URL=        # custom chainweb node; default @stoachain constants
# KHRONOTON_NETWORK_ID=           # kadena network id override
# KHRONOTON_NAMESPACE=            # namespace override
# KHRONOTON_GAS_STATION=          # gas station account override
